rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function protectedBillingFields() {
      return [
        'isPro',
        'proExpiry',
        'lastVerifiedAt',
        'entitlementState',
        'subscriptionState',
        'purchaseToken',
        'purchaseTokenHash',
        'linkedPurchaseToken',
        'linkedPurchaseTokenHash',
        'subscriptionId',
        'expiryTimeMillis',
        'paymentState',
        'verificationSource',
        'notificationType',
        'latestOrderId',
        'regionCode',
        'basePlanId',
        'offerId',
        'offerTags',
        'grantCampaignId'
      ];
    }

    match /app_config/android_update_policy {
      allow read: if true;
      allow write: if false;
    }

    match /app_config/legacy_premium_grant {
      allow read: if true;
      allow write: if false;
    }

    match /billing_purchase_tokens/{doc} {
      allow read, write: if false;
    }

    match /billing_events/{doc} {
      allow read, write: if false;
    }

    match /legacy_premium_grants/{doc} {
      allow read, write: if false;
    }

    // A user can only read/write their own document
    match /users/{userId} {
      allow read: if isOwner(userId);
      // Prevent clients from creating or modifying server-owned billing status fields.
      allow create: if isOwner(userId)
                    && !request.resource.data.keys().hasAny(protectedBillingFields());
      allow update: if isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedBillingFields());
      allow delete: if false;

      // Entitlement snapshot — written by the server (Cloud Function) and
      // readable by the owning user only
      match /entitlements/{doc} {
        allow read: if isOwner(userId);
        // Write is server-only (Cloud Function uses Admin SDK which bypasses rules)
        allow write: if false;
      }

      // Salary plans — owned by the user
      match /plans/{doc} {
        allow read, write: if isOwner(userId);
      }

      // Rules — owned by the user
      match /rules/{doc} {
        allow read, write: if isOwner(userId);
      }

      // Goals — owned by the user
      match /goals/{doc} {
        allow read, write: if isOwner(userId);
      }

      // Settings (including reminders and automation) — owned by the user
      match /settings/{doc} {
        allow read, write: if isOwner(userId);
      }

      match /reviews/{doc} {
        allow read, write: if isOwner(userId);
      }

      match /adjustments/{doc} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
