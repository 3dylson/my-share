rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User-owned avatars / exports — only the owning user can access
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // No other paths are publicly readable
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
